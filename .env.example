# Server
NODE_ENV=development
PORT=4000

# Postgres (Better Auth)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spotsync_bff

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-character-secret
BETTER_AUTH_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:3000

# Go API proxy + shared JWT secret (must match Go JWT_SECRET)
GO_API_BASE_URL=http://localhost:8081
JWT_SECRET=replace-with-shared-go-jwt-secret
JWT_EXPIRY_SECONDS=300

# Stripe TEST mode (optional locally)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: forward to spotsync-notify
NOTIFY_URL=http://localhost:3100
NOTIFY_INTERNAL_TOKEN=change-me-internal-token
